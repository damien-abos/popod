FROM alpine:3.19.0

ENV STUNNEL_FOREGROUND=yes
ENV STUNNEL_UID=stunnel
ENV STUNNEL_GUID=stunnel
ENV STUNNEL_CERT_PATH=/etc/stunnel/certs
ENV STUNNEL_CERT_FILE=${STUNNEL_CERT_PATH}/stunnel-fullchain.pem
ENV STUNNEL_KEY_FILE=${STUNNEL_CERT_PATH}/stunnel-key.pem
ENV STUNNEL_CAROOT_PATH=${STUNNEL_CERT_PATH}
ENV STUNNEL_CAROOT_FILE=${STUNNEL_CAROOT_PATH}/ca.pem
ENV STUNNEL_CRL_PATH=${STUNNEL_CERT_PATH}
ENV STUNNEL_CRL_FILE=${STUNNEL_CRL_PATH}/ca.pem
ENV STUNNEL_COMPRESSION=
ENV STUNNEL_VERIFY=1
ENV STUNNEL_SERVICE=service
ENV STUNNEL_SERVICE_ACCEPT=443
ENV STUNNEL_SERVICE_CONNECT=80
ENV STUNNEL_SERVICE_TIMEOUTCLOSE=0
ENV STUNNEL_SERVICE_TRANSPARENT=no

RUN echo "addgroup ${STUNNEL_GUID}" \
    && echo "adduser -S -D -H -s /sbin/nologin -G ${STUNNEL_GUID} ${STUNNEL_UID}"

RUN  \
  echo "**** install packages ****" && \apk add --co-cache \
  stunnel \
  envsubst \



COPY entrypoint.sh stunnel.conf.tpl /

VOLUME [ ${STUNNEL_CERT_PATH} ]

USER ${STUNNEL_UID}

EXPOSE ${STUNNEL_ACCEPT}

ENTRYPOINT [ "/entrypoint.sh" ]
